# Runtime environment. Controls log format (json in production, console in dev)
# and disables certain safety checks in local mode.
IRIS_ENV=development

# PostgreSQL connection string. Port 5488 is the host-side remap from compose.dev.yaml
IRIS_DATABASE_URL=postgresql://iris:iris@localhost:5488/iris  # pragma: allowlist secret

# Redis connection string. Port 6399 is the host-side remap from compose.dev.yaml.
IRIS_REDIS_URL=redis://localhost:6399/0

# Dev-mode auth seam. Set to "1" to trust X-Iris-Tenant and X-Iris-Roles headers locally.
# Must be absent (or "0") in staging and production.
IRIS_DEV_AUTH=1

# --- OCR adapters -----------------------------------------------------------

# Azure Document Intelligence (ADI) adapter (iris-ocr-adi).
# Required when any Product bundle sets adapters.ocr: adi.
IRIS_ADI_ENDPOINT=https://<resource>.cognitiveservices.azure.com
IRIS_ADI_API_KEY=<subscription-key>  # pragma: allowlist secret
# Optional: ADI model to use. Defaults to prebuilt-layout.
# IRIS_ADI_MODEL=prebuilt-layout

# Set to "1" to run live ADI integration tests against the real endpoint.
# Requires IRIS_ADI_ENDPOINT and IRIS_ADI_API_KEY to be set.
# IRIS_OCR_LIVE_ADI=1

# Datalab adapter (iris-ocr-datalab).
# Required when any Product bundle sets adapters.ocr: datalab.
DATALAB_API_KEY=<api-key>  # pragma: allowlist secret

# Set to "1" to run live Datalab integration tests against the real endpoint.
# Requires DATALAB_API_KEY to be set.
# IRIS_OCR_LIVE_DATALAB=1
