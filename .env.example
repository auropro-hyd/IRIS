# Runtime environment. Controls log format (json in production, console in dev)
# and disables certain safety checks in local mode.
IRIS_ENV=development

# PostgreSQL connection string. Port 5488 is the host-side remap from compose.dev.yaml
IRIS_DATABASE_URL=postgresql://iris:iris@localhost:5488/iris  # pragma: allowlist secret

# Redis connection string. Port 6399 is the host-side remap from compose.dev.yaml.
IRIS_REDIS_URL=redis://localhost:6399/0

# Dev-mode auth seam. Set to "1" to trust X-Iris-Tenant and X-Iris-Roles headers locally.
# Must be absent (or "0") in staging and production.
IRIS_DEV_AUTH=1

# --- OCR adapters -----------------------------------------------------------

# Azure Document Intelligence (ADI) adapter (iris-ocr-adi).
# Required when any Product bundle sets adapters.ocr: adi.
IRIS_ADI_ENDPOINT=https://<resource>.cognitiveservices.azure.com
IRIS_ADI_API_KEY=<subscription-key>  # pragma: allowlist secret
# Optional: ADI model to use. Defaults to prebuilt-layout.
# IRIS_ADI_MODEL=prebuilt-layout

# Set to "1" to run live ADI integration tests against the real endpoint.
# Requires IRIS_ADI_ENDPOINT and IRIS_ADI_API_KEY to be set.
# IRIS_OCR_LIVE_ADI=1

# Datalab adapter (iris-ocr-datalab).
# Required when any Product bundle sets adapters.ocr: datalab.
DATALAB_API_KEY=<api-key>  # pragma: allowlist secret

# Set to "1" to run live Datalab integration tests against the real endpoint.
# Requires DATALAB_API_KEY to be set.
# IRIS_OCR_LIVE_DATALAB=1

# PaddleOCR adapter (iris-ocr-paddleocr).
# No credentials required for online mode - model downloads from HuggingFace on first use.

# Set to "1" to load the model from a local snapshot instead of HuggingFace.
# Requires IRIS_PADDLEOCR_MODEL_PATH to also be set or the adapter raises at startup.
# IRIS_PADDLEOCR_OFFLINE=1
# IRIS_PADDLEOCR_MODEL_PATH=/path/to/PaddleOCR-VL-1.6-snapshot

# For fully airgapped deployments: also set these HuggingFace library vars so no
# network calls are attempted anywhere in the process. Set alongside IRIS_PADDLEOCR_OFFLINE=1.
# TRANSFORMERS_OFFLINE=1
# HF_DATASETS_OFFLINE=1

# Set to "1" to run live PaddleOCR integration tests against the real model.
# Requires the model to be downloaded or IRIS_PADDLEOCR_OFFLINE=1 + model path set.
# IRIS_OCR_LIVE_PADDLEOCR=1

# --- LLM adapters -----------------------------------------------------------

# Azure OpenAI adapter (iris-llm-azure-openai).
# Required when any Product bundle sets adapters.llm: azure-openai.
IRIS_LLM_AZURE_RESOURCE=<resource-name>
IRIS_LLM_AZURE_API_KEY=<api-key>  # pragma: allowlist secret
IRIS_LLM_AZURE_DEPLOYMENT_CHAT=<deployment-name-for-chat>
IRIS_LLM_AZURE_DEPLOYMENT_EXTRACT=<deployment-name-for-extraction>
# Optional: Azure OpenAI API version. Defaults to 2024-02-01.
# IRIS_LLM_AZURE_API_VERSION=2024-02-01

# Set to "1" to run live Azure OpenAI integration tests against the real endpoint.
# Requires all IRIS_LLM_AZURE_* vars above to be set.
# IRIS_LLM_LIVE_AZURE=1

# OpenAI adapter (iris-adapter-llm-openai).
# Required when any Product bundle sets adapters.llm: openai.
IRIS_LLM_OPENAI_API_KEY=<api-key>  # pragma: allowlist secret
# Optional: model overrides. Both default to gpt-4o-mini.
# IRIS_LLM_OPENAI_MODEL_CHAT=gpt-4o-mini
# IRIS_LLM_OPENAI_MODEL_EXTRACT=gpt-4o-mini

# Set to "1" to run live OpenAI integration tests against the real endpoint.
# Requires IRIS_LLM_OPENAI_API_KEY to be set.
# IRIS_LLM_LIVE_OPENAI=1

# ── Anthropic adapter (iris-adapter-llm-anthropic) ───────────────────────────
IRIS_LLM_ANTHROPIC_API_KEY=<sk-ant-api-key>  # pragma: allowlist secret
# IRIS_LLM_ANTHROPIC_MODEL_CHAT=claude-haiku-4-5-20251001
# IRIS_LLM_ANTHROPIC_MODEL_EXTRACT=claude-haiku-4-5-20251001

# Set to "1" to run live Anthropic integration tests against the real endpoint.
# Requires IRIS_LLM_ANTHROPIC_API_KEY to be set.
# IRIS_LLM_LIVE_ANTHROPIC=1

# ── Local adapter (iris-adapter-llm-local) ────────────────────────────────────
# Required when any Product bundle sets adapters.llm: local.
# Targets any OpenAI-compatible local server (Ollama, vLLM, llama.cpp).
IRIS_LLM_LOCAL_MODEL=mistral

# Base URL of the local inference server. Default: http://localhost:8080/v1
# Ollama default: http://localhost:11434/v1
# IRIS_LLM_LOCAL_URL=http://localhost:11434/v1

# Optional bearer token. Leave unset if the server requires no auth (Ollama default).
# IRIS_LLM_LOCAL_API_KEY=<bearer-token>  # pragma: allowlist secret

# Set to "1" to run live local LLM tests against the configured server.
# Requires IRIS_LLM_LOCAL_MODEL and a running server at IRIS_LLM_LOCAL_URL.
# IRIS_LLM_LIVE_LOCAL=1
